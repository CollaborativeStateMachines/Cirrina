amends "modulepath:/pkl/csm/csml.pkl"

version = "4.0.0"
collaborativeStateMachine {
  stateMachines {
    ["invokeStateMachine"] = new StateMachine {
      states {
        ["a"] = new Initial {
          after {
            ["timeout"] = new Timeout {
              delay = "100"
              triggers = new Emit { event = new Internal { topic = "update" } }
            }
          }
          on {
            ["update"] = new Transition {
              to = "a"
              yields {
                new Invoke {
                  type = "increment"
                  mode = "local"
                  input { ["v"] = "v" }
                  emits { new Internal { topic = "tob" } }
                }
                new Assign { expression = "e = e + 1" }
              }
            }
            ["tob"] = new Transition { to = "b" }
          }
        }
        ["b"] = new State {
          entry { new Assign { expression = "v = $v" } }
          always {
            new Transition {
              to = "a"
              provided = "v < 10"; or = "c"
            }
          }
        }
        ["c"] = new Terminal {}
      }
    }
  }
  persistent { ["v"] = "0"; ["e"] = "0"; }
}
instances {
  ["invoke"] = new Instance { stateMachineName = "invokeStateMachine" }
}
bindings {
  new HttpServiceImplementationBinding {
    name = "increment"
    `local` = true
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/increment"
    method = "GET"
  }
}