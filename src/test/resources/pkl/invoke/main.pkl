amends "modulepath:/pkl/csm/csml.pkl"

collaborativeStateMachine {
  stateMachines {
    ["invokeStateMachine"] = new StateMachine {
      states {
        ["a"] = new Initial {
          after {
            ["timeout"] = new Timeout {
              delay = "1"
              triggers = new Emit { event = new Internal { topic = "update" } }
            }
          }
          on {
            ["update"] = new Transition {
              to = "a"
              yields {
                new Invoke {
                  type = "increment"
                  mode = "local"
                  input { ["v"] = "v" }
                  output { "v" }
                  emits { new ConditionalEvent { provided = "v >= 100"; event = new Internal { topic = "tob" } } }
                }
              }
            }
            ["tob"] = new Transition { to = "b" }
          }
        }
        ["b"] = new Terminal {}
      }
    }
  }
  persistent { ["v"] = "0"; ["e"] = "0"; }
}
instances {
  ["invoke"] = new Instance { stateMachineName = "invokeStateMachine" }
}
bindings {
  new HttpServiceImplementationBinding {
    name = "increment"
    `local` = true
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/increment"
    method = "GET"
  }
}