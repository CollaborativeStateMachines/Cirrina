amends "modulepath:/pkl/csm/Csml.pkl"
import "modulepath:/pkl/csm/Csml.pkl"

version = "3.0.0"
stateMachines {
  ["stateMachine1"] = new Csml.StateMachine {
    states {
      ["a"] = new Csml.Initial {
        after {
          ["timeout"] = new Csml.Timeout {
            delay = "100"
            do = new Csml.Raise { event = new Csml.Internal { topic = "update" } }
          }
        }
        on {
          ["update"] = new Csml.Transition {
            to = "a"
            do {
              new Csml.Invoke {
                type = "increment"
                mode = "local"
                input { ["v"] = "v" }
                raises { new Csml.Internal { topic = "tob" } }
              }
              new Csml.Eval { expression = "e = e + 1" }
            }
          }
          ["tob"] = new Csml.Transition { to = "b" }
        }
      }
      ["b"] = new Csml.State {
        entry {
          new Csml.Eval { expression = "v = $v" }
        }
        always {
          new Csml.Transition {
            to = "a"
            iif { "v < 10" }
            or = "c"
          }
        }
      }
      ["c"] = new Csml.Terminal {}
    }
  }
}