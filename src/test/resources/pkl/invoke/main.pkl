amends "modulepath:/pkl/csm/csml.pkl"
import "invokeStateMachine.pkl"

version = "4.0.0"
collaborativeStateMachine {
  stateMachines {
    ["invokeStateMachine"] = invokeStateMachine.sm
  }
  persistent { ["v"] = "0"; ["e"] = "0"; }
}
instances {
  ["invoke"] = new Instance { stateMachineName = "invokeStateMachine" }
}
bindings {
  new HttpServiceImplementationBinding {
    name = "increment"
    `local` = true
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/increment"
    method = "GET"
  }
}