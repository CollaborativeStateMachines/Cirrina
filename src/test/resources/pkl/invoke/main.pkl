amends "modulepath:/pkl/csm/Csml.pkl"
import "modulepath:/pkl/csm/Csml.pkl"

name = "invoke"
version = "3.0.0"
stateMachines {
  new Csml.StateMachine {
    name = "stateMachine1"
    states {
      new Csml.InitialState {
        name = "a"
        after {
          new Csml.Timeout {
            name = "timeout"
            delay = "100"
            action = new Csml.Raise {
              event {
                topic = "update"
                channel = "internal"
              }
            }
          }
        }
        on {
          new Csml.Transition {
            event = "update"
            target = "a"
            actions {
              new Csml.Invoke {
                serviceType = "increment"
                isLocal = true
                input {
                  ["v"] = "v"
                }
                done {
                  new Csml.Event {
                    topic = "tob"
                    channel = "internal"
                  }
                }
              }
              new Csml.Eval {
                expression = "e = e + 1"
              }
            }
          }
          new Csml.Transition {
            event = "tob"
            target = "b"
          }
        }
      }
      new Csml.State {
        name = "b"
        entry {
          new Csml.Eval {
            expression = "v = $v"
          }
        }
        always {
          new Csml.Transition {
            target = "a"
            guards {
              "v < 10"
            }
            or = "c"
          }
        }
      }
      new Csml.TerminalState {
        name = "c"
      }
    }
  }
}