amends "modulepath:/pkl/csm/Csml.pkl"
import "modulepath:/pkl/csm/Csml.pkl"

version = "3.0.0"
stateMachines {
  ["stateMachine1"] = new Csml.StateMachine {
    states {
      ["a"] = new Csml.InitialState {
        after {
          new Csml.Timeout {
            name = "timeout"
            delay = "100"
            action = new Csml.Raise {
              event {
                topic = "update"
                channel = "internal"
              }
            }
          }
        }
        on {
          ["update"] = new Csml.Transition {
            to = "a"
            actions {
              new Csml.Invoke {
                serviceType = "increment"
                isLocal = true
                input {
                  ["v"] = "v"
                }
                done {
                  new Csml.Event {
                    topic = "tob"
                    channel = "internal"
                  }
                }
              }
              new Csml.Eval {
                expression = "e = e + 1"
              }
            }
          }
          ["tob"] = new Csml.Transition {
            to = "b"
          }
        }
      }
      ["b"] = new Csml.State {
        entry {
          new Csml.Eval {
            expression = "v = $v"
          }
        }
        always {
          new Csml.Transition {
            to = "a"
            guards {
              "v < 10"
            }
            or = "c"
          }
        }
      }
      ["c"] = new Csml.TerminalState {}
    }
  }
}