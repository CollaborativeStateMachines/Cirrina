amends "modulepath:/pkl/csm/Csml.pkl"
import "modulepath:/pkl/csm/Csml.pkl"

name = "invoke"
version = "3.0.0"
stateMachines {
  new {
    name = "stateMachine1"
    states {
      new {
        name = "a"
        initial = true
        after {
          new {
            name = "timeout"
            delay = "100"
            action = new {
              event {
                topic = "update"
                channel = "internal"
              }
            }
          }
        }
        on {
          new {
            event = "update"
            target = "a"
            actions {
              new Csml.InvokeAction {
                serviceType = "increment"
                isLocal = true
                input {
                  new {
                    name = "v"
                    value = "v"
                  }
                }
                done {
                  new {
                    topic = "tob"
                    channel = "internal"
                  }
                }
              }
              new Csml.AssignAction {
                variable {
                  name = "e"
                  value = "e + 1"
                }
              }
            }
          }
          new {
            event = "tob"
            target = "b"
          }
        }
      }
      new {
        name = "b"
        entry {
          new Csml.AssignAction {
            variable {
              name = "v"
              value = "$v"
            }
          }
        }
        always {
          new {
            target = "a"
            guards {
              "v < 10"
            }
            or = "c"
          }
        }
      }
      new {
        name = "c"
        terminal = true
      }
    }
  }
}