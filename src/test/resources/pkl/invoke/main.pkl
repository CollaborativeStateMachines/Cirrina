amends "modulepath:/pkl/csm/csml.pkl"
import "invokeStateMachine.pkl"

version = "4.0.0"
collaborativeStateMachine {
  stateMachines {
    ["invokeStateMachine"] = invokeStateMachine.sm
  }
  persistent { ["v"] = "0"; ["e"] = "0"; }
}
instantiate {
  ["invoke"] = "invokeStateMachine"
}
subscriptions {}