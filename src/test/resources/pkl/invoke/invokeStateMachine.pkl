import "modulepath:/pkl/csm/csml.pkl"

sm = new csml.StateMachine {
  states {
    ["a"] = new csml.Initial {
      after {
        ["timeout"] = new csml.Timeout {
          delay = "100"
          do = new csml.Raise { event = new csml.Internal { topic = "update" } }
        }
      }
      on {
        ["update"] = new csml.Transition {
          to = "a"
          do {
            new csml.Invoke {
              type = "increment"
              mode = "local"
              input { ["v"] = "v" }
              raises { new csml.Internal { topic = "tob" } }
            }
            new csml.Eval { expression = "e = e + 1" }
          }
        }
        ["tob"] = new csml.Transition { to = "b" }
      }
    }
    ["b"] = new csml.State {
      entry {
        new csml.Eval { expression = "v = $v" }
      }
      always {
        new csml.Transition {
          to = "a"
          iif { "v < 10" }
          or = "c"
        }
      }
    }
    ["c"] = new csml.Terminal {}
  }
}