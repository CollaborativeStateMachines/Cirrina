amends "modulepath:/pkl/csm/csml.pkl"
import "noopStateMachine.pkl"

version = "4.0.0"
collaborativeStateMachine {
  stateMachines {
    ["noopStateMachine"] = noopStateMachine.sm
  }
}
instances {
  ["noop"] = new Instance { stateMachineName = "noopStateMachine" }
}
bindings {
  new HttpServiceImplementationBinding {
    name = "myHttpService1"
    `local` = false
    scheme = "https"
    host = "api.example.com"
    port = 443
    endPoint = "/data"
    method = "GET"
  }
  new HttpServiceImplementationBinding {
    name = "myHttpService2"
    `local` = false
    scheme = "https"
    host = "api.example.com"
    port = 443
    endPoint = "/data"
    method = "GET"
  }
}