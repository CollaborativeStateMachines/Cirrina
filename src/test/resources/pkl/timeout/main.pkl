amends "modulepath:/pkl/csm/Csml.pkl"
import "modulepath:/pkl/csm/Csml.pkl"

version = "3.0.0"
stateMachines {
  ["stateMachine1"] = new Csml.StateMachine {
    states {
      ["a"] = new Csml.InitialState {
        after {
          new Csml.Timeout {
            name = "timeout"
            delay = "100"
            action = new Csml.Raise {
              event {
                topic = "update"
                channel = "internal"
              }
            }
          }
        }
        on {
          new Csml.Transition {
            event = "update"
            target = "a"
            actions {
              new Csml.Match {
                value = "v < 10"
                cases {
                  new Csml.Case {
                    of = "true"
                    action = new Csml.Eval {
                      expression = "v = v + 1"
                    }
                  }
                  new Csml.Case {
                    of = "false"
                    action = new Csml.Raise {
                      event {
                        topic = "tob"
                        channel = "internal"
                      }
                    }
                  }
                }
              }
            }
          }
          new Csml.Transition {
            event = "tob"
            target = "b"
          }
        }
      }
      ["b"] = new Csml.TerminalState {}
    }
  }
}
persistentContext {
  ["v"] = "0"
}