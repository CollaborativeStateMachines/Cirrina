amends "modulepath:/pkl/csm/Csml.pkl"
import "modulepath:/pkl/csm/Csml.pkl"

name = "timeout"
version = "3.0.0"
stateMachines {
  new {
    name = "stateMachine1"
    states {
      new {
        name = "a"
        initial = true
        after {
          new {
            name = "timeout"
            delay = "100"
            action = new Csml.Raise {
              event {
                topic = "update"
                channel = "internal"
              }
            }
          }
        }
        on {
          new {
            event = "update"
            target = "a"
            actions {
              new Csml.Match {
                value = "v < 10"
                arms {
                  new {
                    of = "true"
                    action = new Csml.Eval {
                      expression = "v = v + 1"
                    }
                  }
                  new {
                    of = "false"
                    action = new Csml.Raise {
                      event {
                        topic = "tob"
                        channel = "internal"
                      }
                    }
                  }
                }
              }
            }
          }
          new {
            event = "tob"
            target = "b"
          }
        }
      }
      new {
        name = "b"
        terminal = true
      }
    }
  }
}
persistentContext {
  ["v"] = "0"
}