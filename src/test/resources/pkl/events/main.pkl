amends "modulepath:/pkl/csm/csml.pkl"

version = "4.0.0"
collaborativeStateMachine {
  stateMachines {
    ["oneMachine"] = new StateMachine {
      states {
        ["a"] = new Initial {
          on {
            ["e2"] { to = "b" }
            ["e6"] { to = "d" }
          }
        }
        ["b"] {
          entry { new Emit { event { topic = "e3" }; target = "target" } }
          on { ["e4"] { to = "c" } }
        }
        ["c"] = new Terminal {
          entry {
            new Emit { event { topic = "e5" } }
            new Assign { expression = "b = true" }
          }
        }
        ["d"] = new Terminal {}
      }
      nested {
        ["nestedStateMachine1"] {
          states {
            ["a"] = new Initial { on { ["pe1"] { to = "b" } } }
            ["b"] = new Terminal { entry { new Emit { event { channel = "internal"; topic = "e1" } } } }
          }
        }
        ["nestedStateMachine2"] {
          states {
            ["a"] = new Initial { on { ["e1"] { to = "b" } } }
            ["b"] = new Terminal { entry { new Emit { event { channel = "internal"; topic = "e2" } } } }
          }
        }
      }
    }
    ["twoMachine"] = new StateMachine {
      states {
        ["a"] = new Initial { on { ["e3"] { to = "b" } } }
        ["b"] = new Terminal { entry { new Emit { event { topic = "e4" } } } }
      }
    }
    ["threeMachine"] = new StateMachine {
      states {
        ["a"] = new Initial {
          entry { new Emit { event { topic = "e6" } } }
          on { ["e5"] { to = "b" } }
        }
        ["b"] = new Terminal {}
      }
    }
    ["fourMachine"] = new StateMachine {
      states {
        ["a"] = new Initial {
          on {
            ["e3"] { to = "b" }
            ["e5"] { to = "c" }
          }
        }
        ["b"] = new Terminal {}
        ["c"] = new Terminal { entry { new Assign { expression = "c = true" } } }
      }
    }
  }
  persistent { ["b"] = "false"; ["c"] = "false" }
}
instances {
  ["one"] = new Instance {
    stateMachineName = "oneMachine"
    data { ["target"] = "'two'" }
    subscription = Regex("two")
  }
  ["two"] = new Instance { stateMachineName = "twoMachine" }
  ["three"] = new Instance { stateMachineName = "threeMachine" }
  ["four"] = new Instance { stateMachineName = "fourMachine" }
}