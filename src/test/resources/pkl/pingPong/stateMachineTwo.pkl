import "csm:Csml"

//             State Machine Two
// в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
// в”Ӯ                                          в”Ӯ
// в”Ӯ                 e1                       в”Ӯ
// в”Ӯ           в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ                 в”Ӯ
// в”Ӯ          в”Ңв”ҙв”җ          в”Ңв–јв”җ  v >= 100  в”Ңв”Җв”җ в”Ӯ
// в”Ӯ raise e4 в”ӮAв”Ӯ raise e2 в”ӮBв”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв–әCв”Ӯ в”Ӯ
// в”Ӯ          в””в–Ів”ҳ  v += 1  в””в”¬в”ҳ            в””в”Җв”ҳ в”Ӯ
// в”Ӯ           в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ                 в”Ӯ
// в”Ӯ                 e3                       в”Ӯ
// в”Ӯ                                          в”Ӯ
// в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
class StateMachine extends Csml.StateMachineDescription {
  name = "stateMachine2"
  states {
    new {
      name = "a"
      initial = true
      entry {
        new Csml.RaiseActionDescription {
          event {
            name = "e4"
            channel = "global"
          }
        }
      }
      on {
        new Csml.OnTransitionDescription {
          event = "e1"
          target = "b"
        }
      }
    }
    new {
      name = "b"
      entry {
        new Csml.AssignActionDescription {
          variable {
            name = "v"
            value = "v + 1"
          }
        }
        new Csml.RaiseActionDescription {
          event {
            name = "e2"
            channel = "global"
          }
        }
      }
      on {
        new Csml.OnTransitionDescription {
          event = "e3"
          target = "a"
        }
      }
      always {
        new Csml.TransitionDescription {
          target = "c"
          guards {
            new Csml.GuardDescription {
              expression = "v >= 100"
            }
          }
        }
      }
    }
    new {
      name = "c"
      terminal = true
    }
  }
}