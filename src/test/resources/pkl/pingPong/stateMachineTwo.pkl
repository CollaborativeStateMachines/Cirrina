import "modulepath:/pkl/csm/Csml.pkl"

class StateMachine extends Csml.StateMachine {
  name = "stateMachine2"
  states {
    new Csml.InitialState {
      name = "a"
      entry {
        new Csml.Raise {
          event {
            topic = "e4"
            channel = "global"
          }
        }
      }
      on {
        new Csml.Transition {
          event = "e1"
          target = "b"
        }
      }
    }
    new Csml.State {
      name = "b"
      entry {
        new Csml.Eval {
          expression = "v = v + 1"
        }
        new Csml.Raise {
          event {
            topic = "e2"
            channel = "global"
          }
        }
      }
      on {
        new Csml.Transition {
          event = "e3"
          target = "a"
        }
      }
      always {
        new Csml.Transition {
          target = "c"
          guards {
            "v >= 100"
          }
        }
      }
    }
    new Csml.TerminalState {
      name = "c"
    }
  }
}