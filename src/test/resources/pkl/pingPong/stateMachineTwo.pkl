import "modulepath:/pkl/csm/Csml.pkl"

class StateMachine extends Csml.StateMachine {
  name = "stateMachine2"
  states {
    new {
      name = "a"
      initial = true
      entry {
        new Csml.RaiseAction {
          event {
            topic = "e4"
            channel = "global"
          }
        }
      }
      on {
        new {
          event = "e1"
          target = "b"
        }
      }
    }
    new {
      name = "b"
      entry {
        new Csml.EvalAction {
          expression = "v = v + 1"
        }
        new Csml.RaiseAction {
          event {
            topic = "e2"
            channel = "global"
          }
        }
      }
      on {
        new {
          event = "e3"
          target = "a"
        }
      }
      always {
        new {
          target = "c"
          guards {
            "v >= 100"
          }
        }
      }
    }
    new {
      name = "c"
      terminal = true
    }
  }
}