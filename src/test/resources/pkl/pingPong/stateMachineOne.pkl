import "modulepath:/pkl/csm/Csml.pkl"

class StateMachine extends Csml.StateMachine {
  states {
    ["a"] = new Csml.InitialState {
      entry {
        new Csml.Eval {
          expression = "v = v + 1"
        }
        new Csml.Raise {
          event {
            topic = "e1"
            channel = "global"
          }
        }
      }
      on {
        ["e2"] = new Csml.Transition {
          to = "b"
        }
      }
    }
    ["b"] = new Csml.State {
      entry {
        new Csml.Raise {
          event {
            topic = "e3"
            channel = "global"
          }
        }
      }
      on {
        ["e4"] = new Csml.Transition {
          to = "a"
        }
      }
      always {
        new Csml.Transition {
          to = "c"
          guards {
            "v >= 100"
          }
        }
      }
    }
    ["c"] = new Csml.TerminalState {}
  }
}