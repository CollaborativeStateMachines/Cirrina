import "modulepath:/pkl/csm/Csml.pkl"

class StateMachine extends Csml.StateMachine {
  name = "stateMachine1"
  states {
    new {
      name = "a"
      initial = true
      entry {
        new Csml.AssignAction {
          variable {
            name = "v"
            value = "v + 1"
          }
        }
        new Csml.RaiseAction {
          event {
            name = "e1"
            channel = "global"
          }
        }
      }
      on {
        new {
          event = "e2"
          target = "b"
        }
      }
    }
    new {
      name = "b"
      entry {
        new Csml.RaiseAction {
          event {
            name = "e3"
            channel = "global"
          }
        }
      }
      on {
        new {
          event = "e4"
          target = "a"
        }
      }
      always {
        new {
          target = "c"
          guards {
            "v >= 100"
          }
        }
      }
    }
    new {
      name = "c"
      terminal = true
    }
  }
}