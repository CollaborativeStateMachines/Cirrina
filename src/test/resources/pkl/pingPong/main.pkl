amends "modulepath:/pkl/csm/csml.pkl"

collaborativeStateMachine {
  stateMachines {
    ["pingStateMachine"] = new StateMachine {
      states {
        ["a"] = new Initial {
          entry {
            new Assign { expression = "v = v + 1" }
            new Emit { event { topic = "e1" } }
          }
          on { ["e2"] = new Transition { to = "b" } }
        }
        ["b"] = new State {
          entry { new Emit { event { topic = "e3" } } }
          on { ["e4"] = new Transition { to = "a" } }
          always {
            new Transition {
              to = "c"
              provided = "v >= 100000"
            }
          }
        }
        ["c"] = new Terminal {}
      }
    }
    ["pongStateMachine"] = new StateMachine {
      states {
        ["a"] = new Initial {
          entry { new Emit { event { topic = "e4" } } }
          on { ["e1"] = new Transition { to = "b" } }
        }
        ["b"] = new State {
          entry {
            new Assign { expression = "v = v + 1" }
            new Emit { event { topic = "e2" } }
          }
          on { ["e3"] = new Transition { to = "a" } }
          always {
            new Transition {
              to = "c"
              provided = "v >= 100000"
            }
          }
        }
        ["c"] = new Terminal {}
      }
    }
  }
  persistent { ["v"] = "0" }
}
instances {
  ["ping"] = new Instance { stateMachineName = "pingStateMachine" }
  ["pong"] = new Instance { stateMachineName = "pongStateMachine" }
}