import "modulepath:/pkl/csm/csml.pkl"

sm = new csml.StateMachine {
  states {
    ["a"] = new csml.Initial {
      entry { new csml.Raise { event = new csml.Global { topic = "e4" } } }
      on { ["e1"] = new csml.Transition { to = "b" } }
    }
    ["b"] = new csml.State {
      entry {
        new csml.Eval { expression = "v = v + 1" }
        new csml.Raise { event = new csml.Global { topic = "e2" } }
      }
      on { ["e3"] = new csml.Transition { to = "a" } }
      always { new csml.Transition { to = "c"; iif { "v >= 100" } } }
    }
    ["c"] = new csml.Terminal {}
  }
}