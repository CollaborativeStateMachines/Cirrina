amends "modulepath:/pkl/csm/csml.pkl"

collaborativeStateMachine {
  stateMachines {
    ["completeStateMachine"] = new StateMachine {
      nested {
        ["nestedStateMachine"] = new StateMachine {
          states {
            ["a"] = new Singleton {
              entry { new Emit { event = new Internal { topic = "ne1" } } }
            }
          }
        }
      }
      states {
        ["a"] = new Initial {
          after {
            ["timeout"] = new Timeout {
              delay = "10"
              triggers = new Emit { event = new Internal { topic = "e1" } }
            }
          }
          on { ["e1"] = new Transition { to = "b" } }
        }
        ["b"] = new State {
          entry {
            new Invoke {
              type = "increment"
              mode = "local"
              input { ["v"] = "x" }
              emits { new Internal { topic = "e2" } }
            }
          }
          exit { new Assign { expression = "e = true" } }
          on {
            ["e2"] = new Transition {
              to = "c"
              yields { new Assign { expression = "x = $v" } }
            }
          }
        }
        ["c"] = new State {
          always {
            new Transition {
              to = "d"
              provided = "x == 100"
              or = "b"
            }
          }
        }
        ["d"] = new State {
          static { ["d"] = "100" }
          entry {
            new Assign { expression = "v = x" }
            new Assign { expression = "d = d - 1" }
            new Match {
              cases {
                new Case {
                  of = "d == 0"
                  yields { new Emit { event = new Internal { topic = "e3" } } }
                }
              }
              default = new Emit { event = new Internal { topic = "e4" } }
            }
          }
          on {
            ["e3"] = new Transition { to = "e" }
            ["e4"] = new Transition { to = "d" }
          }
        }
        ["e"] = new Terminal { entry { new Assign { expression = "b = true" } } }
      }
      transient { ["x"] = "0" }
    }
  }
  persistent { ["b"] = "false"; ["v"] = "0"; ["e"] = "false" }
}
instances {
  ["complete"] = new Instance { stateMachineName = "completeStateMachine" }
}
bindings {
  new HttpServiceImplementationBinding {
    name = "increment"
    `local` = true
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/increment"
    method = "GET"
  }
}