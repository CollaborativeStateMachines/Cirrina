amends "modulepath:/pkl/csm/csml.pkl"
import "completeStateMachine.pkl"

version = "4.0.0"
collaborativeStateMachine {
  stateMachines {
    ["completeStateMachine"] = completeStateMachine.sm
  }
  persistent { ["b"] = "false"; ["v"] = "0"; ["e"] = "false" }
}
instances {
  ["complete"] = new Instance { stateMachineName = "completeStateMachine" }
}
bindings {
  new HttpServiceImplementationBinding {
    name = "increment"
    `local` = true
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/increment"
    method = "GET"
  }
}