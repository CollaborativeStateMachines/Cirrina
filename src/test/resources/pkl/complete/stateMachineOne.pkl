import "modulepath:/pkl/csm/Csml.pkl"
import "nestedStateMachineOne.pkl"

class StateMachine extends Csml.StateMachine {
  stateMachines {
    ["nestedStateMachine1"] = new nestedStateMachineOne.StateMachine {}
  }
  states {
    ["a"] = new Csml.InitialState {
      after {
        new Csml.Timeout {
          name = "timeout"
          delay = "10"
          action = new Csml.Raise {
            event {
              topic = "e1"
              channel = "internal"
            }
          }
        }
      }
      on {
        ["e1"] = new Csml.Transition {
          to = "b"
        }
      }
    }
    ["b"] = new Csml.State {
      entry {
        new Csml.Invoke {
          serviceType = "increment"
          isLocal = true
          input {
            ["v"] = "v"
          }
          done {
            new Csml.Event {
              topic = "e2"
              channel = "internal"
            }
          }
        }
      }
      on {
        ["e2"] = new Csml.Transition {
          to = "c"
          actions {
            new Csml.Eval {
              expression = "v = $v"
            }
          }
        }
      }
    }
    ["c"] = new Csml.State {
      always {
        new Csml.Transition {
          to = "d"
          guards {
            "v >= 100"
          }
        }
        new Csml.Transition {
          to = "b"
          guards {
            "v < 100"
          }
        }
      }
    }
    ["d"] = new Csml.State {
      after {
        new Csml.Timeout {
          name = "timeout"
          delay = "10"
          action = new Csml.Raise {
            event {
              topic = "e3"
              channel = "internal"
            }
          }
        }
      }
      on {
        ["e3"] = new Csml.Transition {
          actions {
            new Csml.Eval {
              expression = "v = v - 1"
            }
            new Csml.Match {
              value = "v"
              cases {
                new Csml.Case {
                  of = "0"
                  action = new Csml.TimeoutReset {
                    action = "timeout"
                  }
                }
                new Csml.Case {
                  of = "0"
                  action = new Csml.Raise {
                    event {
                      topic = "e4"
                      channel = "internal"
                    }
                  }
                }
              }
            }
          }
        }
        ["e4"] = new Csml.Transition {
          to = "e"
        }
      }
    }
    ["e"] = new Csml.TerminalState {}
  }
}