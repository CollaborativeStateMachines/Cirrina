import "modulepath:/pkl/csm/Csml.pkl"
import "nestedStateMachineOne.pkl"

class StateMachine extends Csml.StateMachine {
  name = "stateMachine1"
  stateMachines {
    new nestedStateMachineOne.StateMachine {}
  }
  states {
    new {
      name = "a"
      initial = true
      after {
        new {
          name = "timeout"
          delay = "10"
          action = new {
            event {
              topic = "e1"
              channel = "internal"
            }
          }
        }
      }
      on {
        new {
          event = "e1"
          target = "b"
        }
      }
    }
    new {
      name = "b"
      entry {
        new Csml.InvokeAction {
          serviceType = "increment"
          isLocal = true
          input {
            ["v"] = "v"
          }
          done {
            new {
              topic = "e2"
              channel = "internal"
            }
          }
        }
      }
      on {
        new {
          event = "e2"
          target = "c"
          actions {
            new Csml.EvalAction {
              expression = "v = $v"
            }
          }
        }
      }
    }
    new {
      name = "c"
      always {
        new {
          target = "d"
          guards {
            "v >= 100"
          }
        }
        new {
          target = "b"
          guards {
            "v < 100"
          }
        }
      }
    }
    new {
      name = "d"
      after {
        new Csml.TimeoutAction {
          name = "timeout"
          delay = "10"
          action = new {
            event {
              topic = "e3"
              channel = "internal"
            }
          }
        }
      }
      on {
        new {
          event = "e3"
          actions {
            new Csml.EvalAction {
              expression = "v = v - 1"
            }
            new Csml.MatchAction {
              value = "v"
              arms {
                new {
                  of = "0"
                  action = new Csml.TimeoutResetAction {
                    action = "timeout"
                  }
                }
                new {
                  of = "0"
                  action = new Csml.RaiseAction {
                    event {
                      topic = "e4"
                      channel = "internal"
                    }
                  }
                }
              }
            }
          }
        }
        new {
          event = "e4"
          target = "e"
        }
      }
    }
    new {
      name = "e"
      terminal = true
    }
  }
}