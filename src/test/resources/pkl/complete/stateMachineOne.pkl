import "modulepath:/pkl/csm/Csml.pkl"
import "nestedStateMachineOne.pkl"

class StateMachine extends Csml.StateMachine {
  name = "stateMachine1"
  stateMachines {
    new nestedStateMachineOne.StateMachine {}
  }
  states {
    new Csml.InitialState {
      name = "a"
      after {
        new Csml.Timeout {
          name = "timeout"
          delay = "10"
          action = new Csml.Raise {
            event {
              topic = "e1"
              channel = "internal"
            }
          }
        }
      }
      on {
        new Csml.Transition {
          event = "e1"
          target = "b"
        }
      }
    }
    new Csml.State {
      name = "b"
      entry {
        new Csml.Invoke {
          serviceType = "increment"
          isLocal = true
          input {
            ["v"] = "v"
          }
          done {
            new Csml.Event {
              topic = "e2"
              channel = "internal"
            }
          }
        }
      }
      on {
        new Csml.Transition {
          event = "e2"
          target = "c"
          actions {
            new Csml.Eval {
              expression = "v = $v"
            }
          }
        }
      }
    }
    new Csml.State {
      name = "c"
      always {
        new Csml.Transition {
          target = "d"
          guards {
            "v >= 100"
          }
        }
        new Csml.Transition {
          target = "b"
          guards {
            "v < 100"
          }
        }
      }
    }
    new Csml.State {
      name = "d"
      after {
        new Csml.Timeout {
          name = "timeout"
          delay = "10"
          action = new Csml.Raise {
            event {
              topic = "e3"
              channel = "internal"
            }
          }
        }
      }
      on {
        new Csml.Transition {
          event = "e3"
          actions {
            new Csml.Eval {
              expression = "v = v - 1"
            }
            new Csml.Match {
              value = "v"
              cases {
                new Csml.Case {
                  of = "0"
                  action = new Csml.TimeoutReset {
                    action = "timeout"
                  }
                }
                new Csml.Case {
                  of = "0"
                  action = new Csml.Raise {
                    event {
                      topic = "e4"
                      channel = "internal"
                    }
                  }
                }
              }
            }
          }
        }
        new Csml.Transition {
          event = "e4"
          target = "e"
        }
      }
    }
    new Csml.TerminalState {
      name = "e"
    }
  }
}