import "modulepath:/pkl/csm/Csml.pkl"
import "nestedStateMachineOne.pkl"

class StateMachine extends Csml.StateMachine {
  stateMachines {
    ["nestedStateMachine1"] = new nestedStateMachineOne.StateMachine {}
  }
  states {
    ["a"] = new Csml.Initial {
      after {
        ["timeout"] = new Csml.Timeout {
          delay = "10"
          do = new Csml.Raise {
            event = new Csml.Event {
              topic = "e1"
              channel = "internal"
            }
          }
        }
      }
      on {
        ["e1"] = new Csml.Transition {
          to = "b"
        }
      }
    }
    ["b"] = new Csml.State {
      entry {
        new Csml.Invoke {
          serviceType = "increment"
          `local` = true
          input {
            ["v"] = "v"
          }
          raises {
            new Csml.Event {
              topic = "e2"
              channel = "internal"
            }
          }
        }
      }
      on {
        ["e2"] = new Csml.Transition {
          to = "c"
          do {
            new Csml.Eval {
              expression = "v = $v"
            }
          }
        }
      }
    }
    ["c"] = new Csml.State {
      always {
        new Csml.Transition {
          to = "d"
          iif {
            "v >= 100"
          }
        }
        new Csml.Transition {
          to = "b"
          iif {
            "v < 100"
          }
        }
      }
    }
    ["d"] = new Csml.State {
      after {
        ["timeout"] = new Csml.Timeout {
          delay = "10"
          do = new Csml.Raise {
            event = new Csml.Event {
              topic = "e3"
              channel = "internal"
            }
          }
        }
      }
      on {
        ["e3"] = new Csml.Transition {
          do {
            new Csml.Eval {
              expression = "v = v - 1"
            }
            new Csml.Match {
              value = "v"
              cases {
                new Csml.Case {
                  of = "0"
                  then = new Csml.Reset {
                    name = "timeout"
                  }
                }
                new Csml.Case {
                  of = "0"
                  then = new Csml.Raise {
                    event = new Csml.Event {
                      topic = "e4"
                      channel = "internal"
                    }
                  }
                }
              }
            }
          }
        }
        ["e4"] = new Csml.Transition {
          to = "e"
        }
      }
    }
    ["e"] = new Csml.Terminal {}
  }
}