@ModuleInfo { minPklVersion = "0.29.0" }
module at.ac.uibk.dps.cirrina.csm.Csml

/// The name of an instance of a state machine or "*" to refer to all instances.
typealias InstanceName = String

/// The name of a state machine.
typealias StateMachineName = String

/// The subscription to events raised by state machine instances.
typealias Subscription = String

class InstanceDescription {
  stateMachineName: StateMachineName
  subscription: Regex = Regex(#".*"#)
  data: Context
}

/// The CSML version.
fixed version: String = "4.0.0"

/// The collaborative state machine declaration.
collaborativeStateMachine: CollaborativeStateMachineDescription

/// State machine instances from the collaborative state machine declaration to instantiate.
instances: Mapping<String, Instance>

bindings: Listing<ServiceImplementationBinding>

/// An expression, see <https://commons.apache.org/proper/commons-jexl/reference/syntax.html> for
/// the JEXL expression syntax.
typealias Expression = String

/// The name of a variable.
typealias VariableName = String

/// A context declaration consisting of variable names and value expressions.
typealias Context = Mapping<VariableName, Expression>

class CollaborativeStateMachineDescription {
  persistent: Context
  stateMachines: Mapping<StateMachineName, StateMachineDescription>
}

typealias StateName = String

class StateMachineDescription {
  states: Mapping<StateName, StateDescription>
  nested: Mapping<StateMachineName, StateMachineDescription>
  transient: Context
}

typealias EventName = String

typealias TimeoutName = String

open class StateDescription {
  initial: Boolean = false
  terminal: Boolean = false
  static: Context
  entry: Listing<ActionDescription>
  exit: Listing<ActionDescription>
  during: Listing<ActionDescription>
  after: Mapping<TimeoutName, TimeoutDescription>
  on: Mapping<EventName, TransitionDescription>
  always: Listing<TransitionDescription>
}

class InitialDescription extends StateDescription {
  initial: Boolean = true
}

class TerminalDescription extends StateDescription {
  terminal: Boolean = true
}

class SingletonDescription extends StateDescription {
  initial: Boolean = true
  terminal: Boolean = true
}

class TransitionDescription {
  to: StateName?
  provided: Expression?
  yields: Listing<ActionDescription>
  or: String?
}

abstract class ActionDescription {}

typealias EventTopic = String

typealias EventChannel = "internal"|"external"|"peripheral"

open class EventDescription {
  topic: EventTopic
  channel: EventChannel = "external"
  data: Context
}

class InternalDescription extends EventDescription {
  channel: EventChannel = "internal"
}

typealias InvocationType = String

typealias InvocationMode = "local"|"remote"

class ConditionalEventDescription {
  provided: Expression?
  event: EventDescription
}

class InvokeDescription extends ActionDescription {
  type: InvocationType
  mode: InvocationMode = "remote"
  input: Context
  output: Listing<VariableName>
  emits: Listing<ConditionalEventDescription>
}

class EvalDescription extends ActionDescription {
  expression: Expression
}

class EmitDescription extends ActionDescription {
  event: EventDescription
  target: Expression?
}

class TimeoutDescription extends ActionDescription {
  delay: Expression
  triggers: EmitDescription
}

class ResetDescription extends ActionDescription {
  name: TimeoutName
}

class CaseDescription {
  of: Expression
  yields: Listing<ActionDescription>
}

class MatchDescription extends ActionDescription {
  cases: Listing<CaseDescription>
  default: ActionDescription?
}

class LogDescription extends ActionDescription {
  message: Expression
}

typealias DynamicInstanceName = Pair<String, Expression>

class InstantiateDescription extends ActionDescription {
  instances: Mapping<DynamicInstanceName, Instance>
}

// For internal use only
class CtrDescription extends ActionDescription {
  counter: String
  by: Int = 1
  tags: Mapping<String, Expression>
}

typealias Type = "HTTP"

abstract class ServiceImplementationBinding {
  type: Type
  name: String
  `local`: Boolean
}

typealias HttpMethod = "GET"|"POST"

class HttpServiceImplementationBinding extends ServiceImplementationBinding {
  type: Type = "HTTP"
  scheme: String
  host: String
  port: Int(isBetween(1, 65535))
  endPoint: String
  method: HttpMethod
}

// Alias definitions
typealias Instance = InstanceDescription

typealias CollaborativeStateMachine = CollaborativeStateMachineDescription

typealias StateMachine = StateMachineDescription

typealias State = StateDescription
typealias Initial = InitialDescription
typealias Terminal = TerminalDescription
typealias Singleton = SingletonDescription

typealias Transition = TransitionDescription

// Action aliases
typealias Action = ActionDescription
typealias Eval = EvalDescription
typealias Invoke = InvokeDescription
typealias ConditionalEvent = ConditionalEventDescription
typealias Case = CaseDescription
typealias Match = MatchDescription
typealias Emit = EmitDescription
typealias Timeout = TimeoutDescription
typealias Reset = ResetDescription
typealias Log = LogDescription
typealias Instantiate = InstantiateDescription
typealias Ctr = CtrDescription

// Event aliases
typealias Event = EventDescription
typealias Internal = InternalDescription