@ModuleInfo { minPklVersion = "0.29.0" }
module csm.HttpServiceImplementation

extends "ServiceImplementation.pkl"

import "ServiceImplementation.pkl"

type: ServiceImplementation.Type = "HTTP"
scheme: String
host: String
port: Int(isBetween(1, 65535))
endPoint: String
method: Method

typealias Method = "GET" | "POST"