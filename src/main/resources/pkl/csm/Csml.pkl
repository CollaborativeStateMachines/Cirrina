@ModuleInfo { minPklVersion = "0.29.0" }
module at.ac.uibk.dps.cirrina.csm.Csml

typealias Version = "3.0.0"
typealias Expression = String
typealias Context = Mapping<String, Expression>

version: Version
stateMachines: Mapping<String, StateMachineDescription>
localContext: Context?
persistentContext: Context?

open class StateMachineDescription {
  states: Mapping<String, StateDescription>
  stateMachines: Mapping<String, StateMachineDescription>
  localContext: Context?
}

open class StateDescription {
  initial: Boolean = false
  terminal: Boolean = false
  entry: Listing<ActionDescription>
  exit: Listing<ActionDescription>
  while: Listing<ActionDescription>
  after: Listing<TimeoutDescription>
  on: Listing<TransitionDescription>
  always: Listing<TransitionDescription>
  localContext: Context?
  staticContext: Context?
}

open class InitialStateDescription extends StateDescription {
  initial: Boolean = true
}

open class TerminalStateDescription extends StateDescription {
  terminal: Boolean = true
}

open class SingletonStateDescription extends StateDescription {
  initial: Boolean = true
  terminal: Boolean = true
}

open class TransitionDescription {
  event: String?
  target: String?
  guards: Listing<Expression>
  actions: Listing<ActionDescription>
  or: String?
}

abstract class ActionDescription {
  type: Type
}

typealias Type = "invoke"|"eval"|"raise"|"timeout"|"timeoutReset"|"match"

open class InvokeDescription extends ActionDescription {
  type: Type = "invoke"
  serviceType: String
  isLocal: Boolean = false
  input: Context
  done: Listing<EventDescription>
}

open class EvalDescription extends ActionDescription {
  type: Type = "eval"
  expression: Expression
}

open class RaiseDescription extends ActionDescription {
  type: Type = "raise"
  event: EventDescription
}

open class TimeoutDescription extends ActionDescription {
  type: Type = "timeout"
  name: String
  delay: Expression
  action: RaiseDescription
}

open class TimeoutResetDescription extends ActionDescription {
  type: Type = "timeoutReset"
  action: String
}

class CaseDescription {
  of: Expression
  action: ActionDescription
}

open class MatchDescription extends ActionDescription {
  type: Type = "match"
  value: Expression
  cases: Listing<CaseDescription>
}

typealias EventChannel = "internal"|"external"|"global"|"peripheral"

class EventDescription {
  topic: String
  channel: EventChannel = "global"
  data: Context
}

typealias StateMachine = StateMachineDescription
typealias State = StateDescription
typealias InitialState = InitialStateDescription
typealias TerminalState = TerminalStateDescription
typealias SingletonState = SingletonStateDescription
typealias Transition = TransitionDescription
typealias Action = ActionDescription
typealias Eval = EvalDescription
typealias Invoke = InvokeDescription
typealias Case = CaseDescription
typealias Match = MatchDescription
typealias Raise = RaiseDescription
typealias Timeout = TimeoutDescription
typealias TimeoutReset = TimeoutResetDescription
typealias Event = EventDescription