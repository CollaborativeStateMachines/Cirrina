@ModuleInfo { minPklVersion = "0.29.0" }
module at.ac.uibk.dps.cirrina.csm.Csml

typealias Version = "3.0.0"
typealias Expression = String
typealias Context = Mapping<String, Expression>

name: String
version: Version
stateMachines: Listing<StateMachineDescription>
localContext: Context?
persistentContext: Context?

open class StateMachineDescription {
  name: String
  states: Listing<StateDescription>
  stateMachines: Listing<StateMachineDescription>
  localContext: Context?
}

open class StateDescription {
  name: String
  initial: Boolean = false
  terminal: Boolean = false
  entry: Listing<ActionDescription>
  exit: Listing<ActionDescription>
  while: Listing<ActionDescription>
  after: Listing<TimeoutActionDescription>
  on: Listing<TransitionDescription>
  always: Listing<TransitionDescription>
  localContext: Context?
  staticContext: Context?
}

open class TransitionDescription {
  event: String?
  target: String?
  guards: Listing<Expression>
  actions: Listing<ActionDescription>
  or: String?
}

abstract class ActionDescription {
  type: Type
}

typealias Type = "invoke"|"assign"|"raise"|"timeout"|"timeoutReset"|"match"

open class EvalActionDescription extends ActionDescription {
  type: Type = "assign"
  expression: Expression
}

open class InvokeActionDescription extends ActionDescription {
  type: Type = "invoke"
  serviceType: String
  isLocal: Boolean = false
  input: Context
  done: Listing<EventDescription>
}

class MatchArmDescription {
  of: Expression
  action: ActionDescription
}

open class MatchActionDescription extends ActionDescription {
  type: Type = "match"
  value: Expression
  arms: Listing<MatchArmDescription>
}

open class RaiseActionDescription extends ActionDescription {
  type: Type = "raise"
  event: EventDescription
}

open class TimeoutActionDescription extends ActionDescription {
  type: Type = "timeout"
  name: String
  delay: Expression
  action: RaiseActionDescription
}

open class TimeoutResetActionDescription extends ActionDescription {
  type: Type = "timeoutReset"
  action: String
}

typealias EventChannel = "internal"|"external"|"global"|"peripheral"

class EventDescription {
  topic: String
  channel: EventChannel
  data: Context
}

typealias StateMachine = StateMachineDescription
typealias State = StateDescription
typealias Transition = TransitionDescription
typealias Action = ActionDescription
typealias EvalAction = EvalActionDescription
typealias InvokeAction = InvokeActionDescription
typealias MatchArm = MatchArmDescription
typealias MatchAction = MatchActionDescription
typealias RaiseAction = RaiseActionDescription
typealias TimeoutAction = TimeoutActionDescription
typealias TimeoutResetAction = TimeoutResetActionDescription
typealias Event = EventDescription